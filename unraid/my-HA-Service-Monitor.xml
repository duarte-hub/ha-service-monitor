<?xml version="1.0"?>
<Container version="2">
  <Name>HA-Service-Monitor</Name>
  <Repository>ghcr.io/duarte-hub/ha-service-monitor:latest</Repository>
  <Registry>https://ghcr.io/duarte-hub/ha-service-monitor</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/duarte-hub/ha-service-monitor/issues</Support>
  <Project>https://github.com/duarte-hub/ha-service-monitor</Project>
  <Overview>Monitors Z-Wave JS UI, Zigbee2MQTT, and SLZB coordinator health.</Overview>
  <Category>HomeAutomation:</Category>
  <WebUI>http://[IP]:[PORT:9099]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/duarte-hub/ha-service-monitor/main/unraid/my-HA-Service-Monitor.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/duarte-hub/ha-service-monitor/main/templates/icon.png</Icon>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <Config Name="WebUI Port" Target="9099" Default="9099" Mode="tcp" Description="Web dashboard port" Type="Port" Display="always" Required="true" Mask="false">9099</Config>
  <Config Name="Data Path" Target="/data" Default="/mnt/user/appdata/ha-service-monitor" Mode="rw" Description="Persistent storage for settings and device list" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/ha-monitor</Config>
  <Config Name="HA_URL" Target="HA_URL" Default="http://192.168.0.20:8123" Mode="" Description="Home Assistant base URL" Type="Variable" Display="always" Required="true" Mask="false">http://192.168.0.20:8123</Config>
  <Config Name="HA_TOKEN" Target="HA_TOKEN" Default="" Mode="" Description="Long-lived access token from HA Profile -> Security" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="POLL_INTERVAL" Target="POLL_INTERVAL" Default="30" Mode="" Description="Seconds between health checks" Type="Variable" Display="advanced" Required="false" Mask="false">30</Config>
  <Config Name="TZ" Target="TZ" Default="Australia/Brisbane" Mode="" Description="Timezone" Type="Variable" Display="advanced" Required="false" Mask="false">Australia/Brisbane</Config>
</Container>
